    always {

        allure(
            results: [[path: 'allure-results']]
        )

        publishHTML(target: [
            reportDir: 'playwright-report',
            reportFiles: 'index.html',
            reportName: 'Playwright HTML Report'
        ])

        archiveArtifacts(
            artifacts: 'playwright-report/**,allure-results/**,test-results/**',
            fingerprint: true
        )
    }

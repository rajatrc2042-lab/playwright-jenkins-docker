        stage('Run Kubernetes Job') {
            steps {
                sh '''
                export BROWSER=chromium
                kubectl get jobs -n automation
                kubectl get pods -n automation
                envsubst < k8s/playwright-job.yaml | kubectl apply -f -
                '''

                sh '''
                kubectl wait \
                --for=condition=complete \
                job/playwright-${BROWSER}-${BUILD_NUMBER} \
                -n automation \
                --timeout=120s
                '''

                sh '''
                kubectl logs \
                -n automation \
                -l job-name=playwright-${BROWSER}-${BUILD_NUMBER}
                '''
            }

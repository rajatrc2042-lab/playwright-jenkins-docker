pipeline {
    agent any

    environment {
        ENV = "${params.ENV}"
        SUITES = "${params.SUITES}"
        BROWSERS = "${params.BROWSERS}"
    }

    options {
        timeout(
        time: 30,
        unit: 'MINUTES'
    )
        buildDiscarder(
        logRotator(
            numToKeepStr: '20'
        )
    )
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Kubernetes there') {
            steps {
                sh '''
                kubectl get nodes
                kubectl get ns
                '''
            }
        }

        stage('Run Kubernetes Tests') {
            parallel {
                stage('Chromium') {
                    steps {
                        sh '''
                        export BROWSER=chromium
                        envsubst < k8s/playwright-job.yaml | kubectl apply -f -
                        kubectl wait --for=condition=complete job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation --timeout=120s
                        kubectl logs job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation
                        '''
                    }
                }

                stage('Firefox') {
                    steps {
                        sh '''
                        export BROWSER=firefox
                        envsubst < k8s/playwright-job.yaml | kubectl apply -f -
                        kubectl wait --for=condition=complete job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation --timeout=120s
                        kubectl logs job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation
                        '''
                    }
                }

                stage('WebKit') {
                    steps {
                        sh '''
                        export BROWSER=webkit
                        envsubst < k8s/playwright-job.yaml | kubectl apply -f -
                        kubectl wait --for=condition=complete job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation --timeout=120s
                        kubectl logs job/playwright-${BROWSER}-${BUILD_NUMBER} -n automation
                        '''
                    }
                }
            }
        }

        stage('copy reports from pod to jenkin worksapce') {
            steps {
                sh '''
                POD=$(kubectl get pods -n automation \
                -l job-name=playwright-${BROWSER}-${BUILD_NUMBER} \
                -o jsonpath='{.items[0].metadata.name}')

                kubectl cp automation/$POD:/app/playwright-report ./playwright-report
                kubectl cp automation/$POD:/app/allure-results ./allure-results
                kubectl cp automation/$POD:/app/test-results ./test-results
                '''
            }
        }
        // stage('Run Kubernetes Job') {
        //     steps {
        //         sh '''
        //         export BROWSER=chromium
        //         kubectl get jobs -n automation
        //         kubectl get pods -n automation
        //         envsubst < k8s/playwright-job.yaml | kubectl apply -f -

        //         kubectl wait \
        //         --for=condition=complete \
        //         job/playwright-${BROWSER}-${BUILD_NUMBER} \
        //         -n automation \
        //         --timeout=120s

    //         kubectl logs \
    //         -n automation \
    //         -l job-name=playwright-${BROWSER}-${BUILD_NUMBER}
    //         '''
    //     }
    // }
    }
    post {
            success {
                echo 'Tests Passed'
            }

            failure {
                echo 'Tests Failed'
            }
            always {
                allure(
            includeProperties: false,
            jdk: '',
            results: [[path: 'allure-results']]
        )

            publishHTML(target: [
            allowMissing: false,
            alwaysLinkToLastBuild: true,
            keepAll: true,
            reportDir: 'playwright-report',
            reportFiles: 'index.html',
            reportName: 'Playwright HTML Report'
        ])

                archiveArtifacts(
            artifacts: 'playwright-report/**, test-results/**, allure-results/**',
            fingerprint: true
)

            // cleanWs()
            }
    }
}

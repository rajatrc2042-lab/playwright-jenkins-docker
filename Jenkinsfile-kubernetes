        stage('Run Kubernetes Job') {
            steps {
                script {

                int status = sh(
                script: '''
                export BROWSER=chromium

                envsubst < k8s/playwright-job.yaml | kubectl apply -f -

                kubectl wait \
                  --for=condition=complete \
                  job/playwright-${BROWSER}-${BUILD_NUMBER} \
                  -n automation \
                  --timeout=90s
                ''',
                returnStatus: true
            )

                // Always copy reports
                sh """
                rm -rf allure-results playwright-report test-results
                echo "===== REPORTS ====="
                pwd

                ls -R .

                echo "===== /reports ====="
                ls -R /reports || true

                echo "===== BUILD FOLDER ====="
                ls -R /reports/${BUILD_NUMBER} || true
                cp -r /reports/${BUILD_NUMBER}/chromium/allure-results .
                cp -r /reports/${BUILD_NUMBER}/chromium/playwright-report .
                cp -r /reports/${BUILD_NUMBER}/chromium/test-results .
                """

                if (status != 0) {
                    error("Chromium execution failed")
                }
        }

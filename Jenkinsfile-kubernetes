pipeline {
    agent any

    environment {
        ENV = "${params.ENV}"
        SUITES = "${params.SUITES}"
        BROWSERS = "${params.BROWSERS}"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Kubernetes there') {
            steps {
                sh '''
                kubectl get nodes
                kubectl get ns
                '''
            }
        }

        stage('Run Kubernetes Job') {
            steps {
                sh '''
                kubectl get jobs -n automation
                kubectl get pods -n automation
                kubectl delete job playwright-job -n automation --ignore-not-found=true
                envsubst < k8s/playwright-job.yaml | kubectl apply -f -
                '''

                sh '''
                kubectl wait \
                --for=condition=complete \
                job/playwright-job \
                -n automation \
                --timeout=120s
                '''

                sh '''
                kubectl logs \
                -n automation \
                -l job-name=playwright-job
                '''
            }
        }
    }
}
